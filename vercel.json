{
  "rewrites": [
    {
      "source": "/(reviews/.*|covers/.*|images/.*|privacy_policy/.*|terms_and_conditions/.*|category.json|reviews.json|robots.txt|sitemap.xml)",
      "destination": "/$1"
    },
    {
      "source": "/api/:path*",
      "destination": "http://84.235.166.193:8080/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}